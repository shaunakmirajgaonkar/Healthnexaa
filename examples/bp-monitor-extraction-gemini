# ==========================================
# 2. Extraction Function
# ==========================================
def analyze_screen(image_path: Path, max_retries=5):
    try:
        img = Image.open(image_path)
        img.thumbnail((1024, 1024), Image.LANCZOS)
        if img.mode != 'RGB':
            img = img.convert('RGB')
        print(f"   📐 Resized to {img.size}")
    except (UnidentifiedImageError, Exception) as e:
        print(f"⏭️ Skipping {image_path.name}: unreadable image ({e})")
        return None

    prompt = """Analyze this blood pressure monitor image and extract all visible values.
Return ONLY a valid JSON object with exactly these keys:
{
  "systolic": <int, 0 if unreadable>,
  "diastolic": <int, 0 if unreadable>,
  "pulse": <int, 0 if unreadable>,
  "brand": "<string, 'Unknown' if not visible>",
  "date": "<YYYY-MM-DD or null>",
  "time": "<HH:MM or null>",
  "memory_slot": "<M1, M2, or null>",
  "ihb": <true if irregular heartbeat symbol shown, else false>,
  "afib": <true if afib indicator shown, else false>,
  "error_code": "<string like E1-E5, or null>",
  "user": "<User 1, User 2, or null>",
  "battery_low": <true if battery low indicator shown, else false>,
  "has_glare": <true or false>,
  "confidence": <int 1-10, your confidence in the reading>
}
No extra text, no markdown, just the JSON."""

    attempt = 0
    while attempt < max_retries:
        try:
            response = model.generate_content([prompt, img])
            raw = response.text.strip()
            raw = raw.replace("```json", "").replace("```", "").strip()
            data = json.loads(raw)
            data["file_name"] = image_path.name
            return data

        except Exception as e:
            attempt += 1
            wait_time = (2 ** attempt) * 5
            print(f"⚠️ Error: {e}. Retrying in {wait_time}s... (Attempt {attempt}/{max_retries})")
            time.sleep(wait_time)

    print(f"⏭️ Skipping {image_path.name}: max retries exceeded.")
    return None

# ==========================================
# 3. Main
# ==========================================
def main():
    if not IMAGE_FOLDER_PATH.exists():
        print(f"❌ Directory not found: {IMAGE_FOLDER_PATH}")
        return

    extensions = {'.png', '.jpg', '.jpeg'}
    images = [f for f in IMAGE_FOLDER_PATH.iterdir() if f.suffix.lower() in extensions]

    print(f"🔍 Found {len(images)} images. Starting extraction...")
    print(f"⏱️ Estimated time: ~{len(images) * 4 // 60}m {len(images) * 4 % 60}s\n")

    extracted_rows = []
    skipped = 0

    for i, img_path in enumerate(images, 1):
        print(f"[{i}/{len(images)}] Reading: {img_path.name}...")
        row_data = analyze_screen(img_path)

        if row_data is not None:
            extracted_rows.append(row_data)
            print(f"✅ Done: BP {row_data.get('systolic')}/{row_data.get('diastolic')}, Pulse {row_data.get('pulse')}, Confidence {row_data.get('confidence')}/10")
        else:
            skipped += 1

        if i < len(images):
            print(f"⏳ Waiting 4s...\n")
            time.sleep(4)  # stay under 15 requests/min free tier limit

    print(f"\n✅ Extraction complete. {len(extracted_rows)} succeeded, {skipped} skipped.")

    if not extracted_rows:
        print("⚠️ No data extracted. CSV not saved.")
        return

    df = pd.DataFrame(extracted_rows)
    col_order = ['file_name', 'systolic', 'diastolic', 'pulse', 'brand', 'date', 'time',
                 'memory_slot', 'ihb', 'afib', 'error_code', 'user', 'battery_low',
                 'has_glare', 'confidence']
    existing_cols = [c for c in col_order if c in df.columns]
    df = df[existing_cols]

    csv_path = "medical_data_export.csv"
    df.to_csv(csv_path, index=False)

    print(df.to_string(index=False))
    print(f"\n📊 Table saved as: {csv_path}")

if __name__ == "__main__":
    main()
